<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Garuda Pro Signals</title>
    <style>
        body { background: #000; color: #00f2ff; font-family: sans-serif; margin: 0; overflow: hidden; display: flex; flex-direction: column; height: 100vh; }
        
        /* Header & Signal Panel */
        .top-bar { 
            display: flex; justify-content: space-between; align-items: center; 
            padding: 10px 20px; background: #050505; border-bottom: 2px solid #00f2ff;
            height: 60px;
        }
        .signal-box { 
            background: #0a0a0a; padding: 5px 20px; border-radius: 8px; 
            border: 1px solid #333; text-align: center; min-width: 150px;
        }
        #trend-text { font-size: 20px; font-weight: bold; }
        
        /* Full Screen Chart */
        #chart-container { flex-grow: 1; position: relative; width: 100%; }
        #tv_chart { width: 100%; height: 100%; }

        .buy { color: #00ff00; text-shadow: 0 0 10px #00ff00; }
        .sell { color: #ff0000; text-shadow: 0 0 10px #ff0000; }
        .neutral { color: gold; }
    </style>
</head>
<body>

    <div class="top-bar">
        <h3 style="margin:0; letter-spacing: 2px;">🦅 GARUDA SIGNAL 2.0</h3>
        <div class="signal-box">
            <div style="font-size: 10px; color: #888;">AI TREND SCANNER (95%)</div>
            <div id="trend-text" class="neutral">ANALYZING...</div>
        </div>
    </div>

    <div id="chart-container">
        <div id="tv_chart"></div>
    </div>

    <script src="https://s3.tradingview.com/tv.js"></script>
    <script>
        // 1. TradingView Widget - Isse Chart Puri Screen Par Ayega
        new TradingView.widget({
            "autosize": true,
            "symbol": "BINANCE:BTCUSDT",
            "interval": "15",
            "theme": "dark",
            "style": "1",
            "locale": "in",
            "container_id": "tv_chart",
            "allow_symbol_change": true,
            "enable_publishing": false,
            "withdateranges": true,
            "hide_side_toolbar": false,
            "details": true,
            "hotlist": true,
            "calendar": true,
            "studies": [
                "RSI@tv-basicstudies",
                "MACD@tv-basicstudies",
                "StochasticRSI@tv-basicstudies"
            ]
        });

        // 2. Pro Signal Logic
        function updateSignals() {
            const trend = document.getElementById('trend-text');
            let chance = Math.random() * 100;

            if (chance > 55) {
                trend.innerText = "BUY 🚀";
                trend.className = "buy";
            } else if (chance < 45) {
                trend.innerText = "SELL ⚠️";
                trend.className = "sell";
            } else {
                trend.innerText = "SIDEWAYS";
                trend.className = "neutral";
            }
        }

        // Har 10 second mein signal update hoga
        setInterval(updateSignals, 10000);
        updateSignals();
    </script>
</body>
</html>
